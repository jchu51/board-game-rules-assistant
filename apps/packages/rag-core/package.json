{
  "name": "@board-game-rules-assistant/rag-core",
  "version": "0.1.0",
  "description": "Reusable RAG primitives for the Board Game Rules Assistant.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "tsc --noEmit -p tsconfig.test.json && node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/classic": "^1.0.38",
    "@langchain/core": "^1.2.1",
    "@langchain/openai": "^1.5.3",
    "@langchain/textsplitters": "^1.0.1",
    "pdfjs-dist": "^6.1.200"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
