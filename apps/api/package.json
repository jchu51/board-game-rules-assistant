{
  "name": "api",
  "version": "1.0.0",
  "description": "Board Game Rules Assistant API",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsup src/main.ts --format esm --platform node --target node22 --out-dir dist --clean && cp openapi.yml dist/openapi.yml && cp -R migrations dist/migrations",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@board-game-rules-assistant/agent-core": "^0.1.0",
    "@board-game-rules-assistant/rag-core": "^0.1.0",
    "@langchain/community": "0.3.57",
    "@langchain/tavily": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.15.5",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.11",
    "oxlint": "^1.72.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
